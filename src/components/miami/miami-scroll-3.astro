---
// No props needed for now, but you can add them here if needed
---
<div class="bg-black flex">

<div class="sticky top-4 right-4 flex justify-end"></div>

<div
  data-lottie-container
  class="max-w-[768px] overflow-y-scroll h-dvh relative mx-auto scrollbar-hide"
>

  <div
    lottie-animation
    class="sticky top-0 left-0 right-0 h-dvh overflow-hidden"
  >
  </div>
  <div id="spacer" class=""></div>


  <div 
    id="progress-bar" 
    class="fixed top-4 right-4 text-white bg-opacity-50 px-2 py-1 rounded-md text-sm font-mono"
  >
    0%
  </div>
  <button id="playButton" class="fixed top-4 left-1/2  -translate-x-1/2 z-50">Play</button>
  <button id="skipButton" class=" fixed bottom-4 right-1/2 -translate-x-1/2 z-50">Skip</button>
  <slot />

</div>
</div>

<script>
  import lottie, { type AnimationItem } from "lottie-web";
  import { Howl } from "howler";

  function initScrollAnimation() {
    const element: HTMLElement | null = document.querySelector("[lottie-animation]");
    const container: HTMLElement | null = document.querySelector("[data-lottie-container]");
    const playButton: HTMLElement | null = document.getElementById("playButton");
    const percentageBar: HTMLElement | null = document.getElementById("progress-bar");
    const skipButton: HTMLElement | null = document.getElementById("skipButton");

    let isPlaying: boolean = false;
    let isFinished: boolean = false;
    let progress: number = 0;
    let currentTime: number = 0;
    let currentFrame: number = 0;
    const thresholdScrollVelocity = 0.25;
    let totalFrames: number = 0;

    if (!(element instanceof HTMLElement) || !container || !playButton || !percentageBar || !skipButton) {
      throw new Error("Required elements not found");
    }

    const animation = lottie.loadAnimation({
      container: element,
      renderer: "svg",
      loop: false,
      autoplay: false,
      path: "/miami1/lottie-no-audio.json",
      assetsPath: "/miami1/images/",
    });

    // Add DOMLoaded event listener to get accurate totalFrames
    animation.addEventListener('DOMLoaded', () => {
      totalFrames = animation.totalFrames;
    });


    animation.addEventListener('complete', () => {
      isFinished = true;
      if (playButton) {
        playButton.textContent = "Restart";
      }
      sound.stop();
    });

    const sound = new Howl({
      src: ["/miami1/traccia.mp3"],
      html5: true,
      preload: true,
      onload: () => {
        const durationInSeconds = sound.duration();
        const pixelsPerSecond = 100;
        const spacer = document.getElementById("spacer");
        if (spacer) {
          spacer.style.height = `${durationInSeconds * pixelsPerSecond}px`;
        }
      },
    });

    sound.on("end", () => {
      isFinished = true;
      if (playButton) {
        playButton.textContent = "Restart";
      }
      animation.stop();
    });

    let lastScrollTop = 0;
    let lastScrollTime = Date.now();
    let scrollVelocity = 0;

    const updateProgress = (newProgress: number) => {
      // Clamp progress between 0 and 1
      progress = Math.min(1, Math.max(0, newProgress));
      
      // Update the current time based on total duration and progress
      currentTime = sound.duration() * progress;

      // Update the progress bar display with more precision
      if (percentageBar) {
        // Round to nearest integer but ensure we reach 100%
        const percentage = progress >= 0.995 ? 100 : Math.round(progress * 100);
        percentageBar.textContent = `${percentage}%`;
      }

      // Check if animation has reached the end (use a threshold)
      if (progress >= 0.98) {
        isFinished = true;
        sound.stop();
        animation.stop();
        if (playButton) {
          playButton.textContent = "Restart";
        }
      }
    };

    playButton.addEventListener("click", () => {
      if (isFinished) {
        // Reset everything
        isFinished = false;
        progress = 0;
        currentFrame = 0;
        currentTime = 0;
        sound.seek(0);
        animation.goToAndStop(0, true);
        updateProgress(0);
        
        // Start playing
        sound.play();
        animation.play();
        isPlaying = true;
        playButton.textContent = "Pause";
      } else if (isPlaying) {
        sound.pause();
        animation.pause();
        isPlaying = false;
        playButton.textContent = "Play";
      } else {
        sound.play();
        animation.play();
        isPlaying = true;
        playButton.textContent = "Pause";
      }
    });



    skipButton.addEventListener("click", () => {  
      const currentContainer = container.closest('.bg-black');
      const nextSection = currentContainer?.nextElementSibling;
      
      if (skipButton.textContent === "Skip") {
        // Going down
        playButton.style.display = "none";
        sound.stop();
        sound.seek(sound.duration());
        animation.stop();
        animation.goToAndStop(totalFrames, true);
        isPlaying = false;
        isFinished = true;
        playButton.textContent = "Play";
        skipButton.textContent = "Go back";
        
        if (nextSection) {
          setTimeout(() => {
            nextSection.scrollIntoView({ 
              behavior: 'smooth',
              block: 'start'
            });
          }, 100);
        }
      } else {
        // Going back up
        skipButton.textContent = "Skip";
        playButton.style.display = "block";
        if (currentContainer) {
          setTimeout(() => {
            currentContainer.scrollIntoView({ 
              behavior: 'smooth',
              block: 'start'
            });
          }, 100);
        }
      }
    });

    

    container.addEventListener("scroll", () => {
      if (!sound.playing()) return;
      
      const currentTime = Date.now();
      const scrollTop = container.scrollTop;
      const timeDelta = currentTime - lastScrollTime;

      scrollVelocity = Math.abs(scrollTop - lastScrollTop) / timeDelta;
      scrollVelocity = Math.max(thresholdScrollVelocity, scrollVelocity);

      const minRate = 0.5;
      const maxRate = 2.0;
      const baseRate = 1.0;

      let newRate = baseRate + scrollVelocity * 10;
      newRate = Math.max(minRate, Math.min(maxRate, newRate));

      sound.rate(newRate);
      animation.setSpeed(newRate);

      const scrollHeight = container.scrollHeight - container.clientHeight;
      // More precise progress calculation
      const rawProgress = scrollTop / scrollHeight;
      progress = Math.min(1, Math.max(0, rawProgress));
      const newTime = sound.duration() * progress;
      
      sound.seek(newTime);
      animation.goToAndStop(Math.round(animation.totalFrames * progress), true);
      updateProgress(progress);

      lastScrollTop = scrollTop;
      lastScrollTime = currentTime;

      clearTimeout(window.scrollTimeout);
      window.scrollTimeout = setTimeout(() => {
        // Reset to normal speed when scrolling stops
        sound.rate(1.0);
        animation.setSpeed(1.0);
        animation.play();
      }, 150);
    });



    sound.on("play", () => {
      function updateAnimation() {
        if (sound.playing()) {
          currentFrame =  animation.currentFrame //animation.totalFrames * sound.seek() / sound.duration();
          const currentProgress = sound.seek() / sound.duration();
          animation.goToAndPlay(totalFrames * currentProgress, true);
          updateProgress(currentProgress);
          requestAnimationFrame(updateAnimation);
        }
      }
      requestAnimationFrame(updateAnimation);
    });

    sound.on("seek", () => {
      const currentProgress = sound.seek() / sound.duration();
      updateProgress(currentProgress);
    });

    // Create an intersection observer
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Reset and reinitialize everything when container comes back into view
          sound.stop();
          sound.seek(0);
          animation.stop();
          animation.goToAndStop(0, true);
          isPlaying = false;
          isFinished = false;
          progress = 0;
          currentFrame = 0;
          currentTime = 0;
          playButton.style.display = "block";
          playButton.textContent = "Play";
          skipButton.textContent = "Skip";
          updateProgress(0);
        } else {
          playButton.style.display = "none";
          skipButton.textContent = "Go back";
          animation.stop();
          sound.stop();

        }
      });
    }, {
      threshold: 0.5 // Trigger when at least 50% of the container is visible
    });

    // Start observing the container
    observer.observe(container);

    // Cleanup function to disconnect observer when needed
    return () => {
      observer.disconnect();
    };
  }

  // Initialize the animation when the script runs
  initScrollAnimation();
</script>

<style>
  /* Hide scrollbar for Chrome, Safari and Opera */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  /* Hide scrollbar for IE, Edge and Firefox */
  .scrollbar-hide {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }

  #playButton {
    background-color: rgba(255, 0, 0, 0.8);
    border: none;
    padding: 10px 20px;
    border-radius: 50px;
    cursor: pointer;
    color: white;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  #skipButton {
    background-color: rgba(0, 0, 255, 0.8);
    border: none;
    padding: 10px 20px;
    border-radius: 50px;
    cursor: pointer;
    color: white;
    font-weight: 500;
    transition: all 0.2s ease;
    transform: translateX(50%);
  }

  #skipButton:hover {
    background-color: rgba(0, 0, 255, 1);
    transform: translateX(50%) translateY(-2px);
  }

  #playButton:hover {
    background-color: rgba(255, 0, 0, 1);
    transform: translate(-50%, -2px);
  }
</style>
